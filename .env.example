NODE_ENV=production
PORT=3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_RETRY_ATTEMPTS=3
OPENAI_RETRY_BASE_DELAY_MS=900
OPENAI_TEXT_VERBOSITY=medium
OPENAI_REASONING_EFFORT=medium
SQLITE_DB_PATH=aurora_recruitment.db
DATABASE_URL="mysql://root:YOUR_PASSWORD_URL_ENCODED@localhost:3306/rh_vision?charset=utf8mb4&collation=utf8mb4_unicode_ci"

# ─── Portal / Distribuição ────────────────────────────────────────────────────
# URL pública da plataforma (usada nos feeds e schema.org)
APP_URL=https://app.triagemsmart.com.br

# Nome da plataforma nos feeds (aparece como publisher)
PUBLISHER_NAME=Triagem Smart

# E-mail para candidaturas via Indeed (opcional)
INDEED_APPLY_EMAIL=rh@suaempresa.com.br

# ─── Feeds — URLs geradas automaticamente ─────────────────────────────────────
# Após definir APP_URL, os feeds ficam disponíveis em:
#
#   Feed genérico (Vagas.com.br, Infojobs, agregadores):
#     ${APP_URL}/feed/vagas.xml
#
#   Indeed (cadastro em indeed.com/publisher):
#     ${APP_URL}/feed/indeed.xml
#
#   Jooble (enviar para partnerships@jooble.org):
#     ${APP_URL}/feed/jooble.xml
#
#   Careerjet (careerjet.com.br/content/publisher.html):
#     ${APP_URL}/feed/careerjet.xml
#
#   Talent.com (contato: partnerships@talent.com):
#     ${APP_URL}/feed/talent.xml
#
#   Jobrapido (contato pelo site):
#     ${APP_URL}/feed/jobrapido.xml
#
#   BNE — Banco Nacional de Empregos (plano pago):
#     ${APP_URL}/feed/bne.xml
#
#   Empregos.com.br (parceiros@empregos.com.br):
#     ${APP_URL}/feed/empregos.xml
#
#   Infojobs Brasil (plano pago):
#     ${APP_URL}/feed/infojobs.xml
#
#   Catho (plano pago — anunciante.catho.com.br):
#     ${APP_URL}/feed/catho.xml
#
#   Vagas.com.br (plano pago):
#     ${APP_URL}/feed/vagas-com.xml
#
#   SINE / Emprega Brasil (exportação manual):
#     ${APP_URL}/feed/sine.xml
#
#   Feed JSON universal:
#     ${APP_URL}/feed/vagas.json
